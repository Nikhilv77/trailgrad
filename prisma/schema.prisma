generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  clerkUserId           String    @id @map("clerk_user_id")
  onboardingStatus      String    @default("not_started") @map("onboarding_status")
  currentOnboardingStep String    @default("target-role") @map("current_onboarding_step")
  onboardingStartedAt   DateTime? @map("onboarding_started_at") @db.Timestamptz(6)
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  analysisError         String?   @map("analysis_error")
  onboarding            Json?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  careerContext   CareerContext?
  targetContexts  TargetContext[]
  manualProjects  ManualProject[]
  sourceDocuments SourceDocument[]
  resumeVersions  ResumeVersion[]
  analysisJobs    AnalysisJob[]
  aiRuns          AiRun[]
  profileAnalyses ProfileAnalysis[]
  jobApplications JobApplication[]

  @@index([onboardingStatus], map: "user_profiles_onboarding_status_idx")
  @@index([currentOnboardingStep], map: "user_profiles_current_onboarding_step_idx")
  @@map("user_profiles")
}

enum AnalysisJobType {
  INITIAL_PROFILE
  RESUME_REANALYSIS
  JOB_ANALYSIS
  PROFILE_REASSESSMENT
}

enum AnalysisJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProfileAnalysisStatus {
  PENDING
  COMPLETED
  FAILED
}

model CareerContext {
  profileId                    String      @id @map("profile_id")
  primaryTargetRole            String      @map("primary_target_role")
  experienceLevel              String      @map("experience_level")
  targetCompany                String?     @map("target_company")
  targetJobTitle               String?     @map("target_job_title")
  interviewOrApplicationDate   DateTime?   @map("interview_or_application_date") @db.Date
  noDateYet                    Boolean     @default(false) @map("no_date_yet")
  dailyPreparationMinutes      Int?        @map("daily_preparation_minutes")
  flexiblePreparationTime      Boolean     @default(false) @map("flexible_preparation_time")
  preparationIntensity         String      @map("preparation_intensity")
  timezone                     String?
  createdAt                    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile                      UserProfile @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)

  @@index([primaryTargetRole], map: "career_contexts_primary_target_role_idx")
  @@map("career_contexts")
}

model TargetContext {
  id             String      @id
  profileId      String      @map("profile_id")
  trailFocus     String      @default("job") @map("trail_focus")
  role           String
  company        String?
  jobTitle       String?     @map("job_title")
  jobDescription String?     @map("job_description")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile        UserProfile @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  profileAnalyses ProfileAnalysis[]
  analysisJobs   AnalysisJob[]
  jobApplication JobApplication?

  @@index([profileId], map: "target_contexts_profile_id_idx")
  @@map("target_contexts")
}

model ManualProject {
  id            String      @id
  profileId     String      @map("profile_id")
  name          String
  description   String      @default("")
  projectUrl    String?     @map("project_url")
  repositoryUrl String?     @map("repository_url")
  technologies  String[]    @default([])
  currentStatus String      @default("draft") @map("current_status")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile       UserProfile @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)

  @@unique([profileId, name], map: "manual_projects_profile_name_idx")
  @@index([profileId], map: "manual_projects_profile_id_idx")
  @@index([currentStatus], map: "manual_projects_current_status_idx")
  @@map("manual_projects")
}

model SourceDocument {
  id                String          @id
  profileId         String          @map("profile_id")
  sourceType        String          @map("source_type")
  originalFilename  String          @map("original_filename")
  mimeType          String          @map("mime_type")
  storagePath       String          @unique(map: "source_documents_storage_path_idx") @map("storage_path")
  fileSize          Int             @map("file_size")
  sha256ContentHash String          @map("sha256_content_hash")
  processingStatus  String          @default("UPLOADED") @map("processing_status")
  errorCode         String?         @map("error_code")
  version           Int
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  profile           UserProfile     @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  resumeVersions    ResumeVersion[]
  analysisJobs      AnalysisJob[]

  @@unique([profileId, sourceType, version], map: "source_documents_profile_type_version_idx")
  @@unique([profileId, sourceType, sha256ContentHash], map: "source_documents_profile_type_hash_idx")
  @@index([profileId, sourceType], map: "source_documents_profile_type_idx")
  @@map("source_documents")
}

model AnalysisJob {
  id               String            @id
  profileId        String            @map("profile_id")
  sourceDocumentId String?           @map("source_document_id")
  targetContextId  String?           @map("target_context_id")
  type             AnalysisJobType
  status           AnalysisJobStatus @default(QUEUED)
  currentStage     String            @default("resume_analysis") @map("current_stage")
  progressPercent  Int               @default(0) @map("progress_percent")
  idempotencyKey   String            @unique(map: "analysis_jobs_idempotency_key_idx") @map("idempotency_key")
  attemptCount     Int               @default(0) @map("attempt_count")
  safeErrorCode    String?           @map("safe_error_code")
  safeErrorMessage String?           @map("safe_error_message")
  startedAt        DateTime?         @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime?         @map("completed_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile          UserProfile       @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  sourceDocument   SourceDocument?   @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  targetContext    TargetContext?    @relation(fields: [targetContextId], references: [id], onDelete: SetNull)
  aiRuns           AiRun[]

  @@index([profileId, status], map: "analysis_jobs_profile_status_idx")
  @@index([sourceDocumentId], map: "analysis_jobs_source_document_id_idx")
  @@index([targetContextId], map: "analysis_jobs_target_context_id_idx")
  @@index([type, status], map: "analysis_jobs_type_status_idx")
  @@index([createdAt], map: "analysis_jobs_created_at_idx")
  @@map("analysis_jobs")
}

model JobApplication {
  id                    String         @id
  profileId             String         @map("profile_id")
  targetContextId       String?        @unique(map: "job_applications_target_context_id_idx") @map("target_context_id")
  trailFocus            String         @default("job") @map("trail_focus")
  targetRole            String         @map("target_role")
  experienceLevel       String         @map("experience_level")
  targetCompany         String?        @map("target_company")
  targetJobTitle        String?        @map("target_job_title")
  applicationDate       DateTime?      @map("application_date") @db.Date
  noDateYet             Boolean        @default(false) @map("no_date_yet")
  preparationTimePerDay String         @map("preparation_time_per_day")
  preparationIntensity  String         @map("preparation_intensity")
  targetJobMode         String         @default("skip") @map("target_job_mode")
  jobDescription        String?        @map("job_description")
  analysisJobId         String?        @map("analysis_job_id")
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile               UserProfile    @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  targetContext         TargetContext? @relation(fields: [targetContextId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt], map: "job_applications_profile_created_at_idx")
  @@map("job_applications")
}

model AiRun {
  id               String       @id
  profileId        String?      @map("profile_id")
  analysisJobId    String?      @map("analysis_job_id")
  provider         String
  operation        String
  model            String
  promptVersion    String       @map("prompt_version")
  inputTokens      Int?         @map("input_tokens")
  outputTokens     Int?         @map("output_tokens")
  cachedTokens     Int?         @map("cached_tokens")
  estimatedCostUsd Decimal      @default(0) @map("estimated_cost_usd") @db.Decimal(12, 6)
  durationMs       Int          @map("duration_ms")
  status           String
  usedFallback     Boolean      @default(false) @map("used_fallback")
  safeErrorCode    String?      @map("safe_error_code")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  profile          UserProfile? @relation(fields: [profileId], references: [clerkUserId], onDelete: SetNull)
  analysisJob      AnalysisJob? @relation(fields: [analysisJobId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt], map: "ai_runs_profile_created_at_idx")
  @@index([analysisJobId], map: "ai_runs_analysis_job_id_idx")
  @@index([provider, model], map: "ai_runs_provider_model_idx")
  @@index([operation], map: "ai_runs_operation_idx")
  @@index([createdAt], map: "ai_runs_created_at_idx")
  @@map("ai_runs")
}

model ResumeVersion {
  id                  String         @id
  profileId           String         @map("profile_id")
  sourceDocumentId    String         @map("source_document_id")
  version             Int
  extractedTextStatus String         @default("UPLOADED") @map("extracted_text_status")
  extractedText       String?        @map("extracted_text")
  errorCode           String?        @map("error_code")
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  profile             UserProfile    @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  sourceDocument      SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  profileAnalyses     ProfileAnalysis[]

  @@unique([profileId, version], map: "resume_versions_profile_version_idx")
  @@index([profileId], map: "resume_versions_profile_id_idx")
  @@map("resume_versions")
}

model ProfileAnalysis {
  id              String                @id
  profileId       String                @map("profile_id")
  resumeVersionId String                @map("resume_version_id")
  targetContextId String?               @map("target_context_id")
  status          ProfileAnalysisStatus @default(PENDING)
  result          Json?
  promptVersion   String                @map("prompt_version")
  provider        String
  model           String
  safeErrorCode   String?               @map("safe_error_code")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile         UserProfile           @relation(fields: [profileId], references: [clerkUserId], onDelete: Cascade)
  resumeVersion   ResumeVersion         @relation(fields: [resumeVersionId], references: [id], onDelete: Restrict)
  targetContext   TargetContext?        @relation(fields: [targetContextId], references: [id], onDelete: SetNull)

  @@index([profileId, status], map: "profile_analyses_profile_status_idx")
  @@index([resumeVersionId], map: "profile_analyses_resume_version_id_idx")
  @@index([targetContextId], map: "profile_analyses_target_context_id_idx")
  @@index([createdAt], map: "profile_analyses_created_at_idx")
  @@map("profile_analyses")
}
